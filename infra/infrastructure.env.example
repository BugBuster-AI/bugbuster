#### INFRASTRUCTURE ####

### MINIO ###
MINIO_HOST=minio
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_PORT=9000
MINIO_PORT_UI=9001
MINIO_SECURE=0

# MINIO_ACCESS_KEY / MINIO_SECRET_KEY
# Used by:
# - minio
# - langfuse
# - services
# Regeneration requires full docker compose restart

### POSTGRES ###
DB_HOST=postgres
DB_USER=postgres
DB_PASS=postgres
DB_PORT=5432

### REDIS ###
REDIS_HOST=redis
REDIS_PASSWORD=redispassword
REDIS_PORT=6379

### RABBITMQ ###
RABBIT_HOST=rabbitmq
RABBIT_USER=demo
RABBIT_PASSWORD=demo
RABBIT_PORT=5672
RABBIT_PORT_UI=15672

### CLICKHOUSE ###
CLICKHOUSE_DB=bugbuster_db
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_NATIVE_PORT=9100
CLICKHOUSE_INTER_SERVER_PORT=9109
CLICKHOUSE_HTTP_PORT=8123
