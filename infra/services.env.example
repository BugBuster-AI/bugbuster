# IF YOU USE SELF-HOSTED VLLM:
# INFERENCE_BASE_URL=http://vllm_ip:8001/v1
# INFERENCE_API_KEY=
# INFERENCE_MODEL_NAME=qwen3-vl-8b-instruct
# SOP_REWRITER_BASE_URL=http://vllm_ip:8001/v1
# SOP_REWRITER_API_KEY=
# SOP_REWRITER_MODEL_NAME=qwen/qwen3-vl-8b-instruct
# SOP_REWRITER_PROVIDER=vllm

# Playwright codegen agent: по умолчанию та же модель и endpoint, что INFERENCE_* (qwen/qwen3-vl-8b-instruct — координаты и reasoning на платформе). Переопределяйте CODEGEN_AGENT_* только если вынесли codegen на отдельный сервис/модель.

# IF YOU USE OPENROUTER (по умолчанию = как INFERENCE_* выше):
CODEGEN_AGENT_BASE_URL=https://openrouter.ai/api/v1
CODEGEN_AGENT_API_KEY=
CODEGEN_AGENT_MODEL_NAME=qwen/qwen3-vl-235b-a22b-instruct
CODEGEN_AGENT_PROVIDER=openai

# IF YOU USE SELF-HOSTED VLLM (по умолчанию = как закомментированный блок INFERENCE_*):
# CODEGEN_AGENT_BASE_URL=http://vllm_ip:8001/v1
# CODEGEN_AGENT_API_KEY=
# CODEGEN_AGENT_MODEL_NAME=qwen3-vl-8b-instruct
# CODEGEN_AGENT_PROVIDER=vllm

