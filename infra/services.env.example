### CLICKER ###
CONCURRENCY=20
LOCALHOST_DISABLED=0
# Значения ниже обязательно оставлять раскомментированными при использовании этого файла как env для docker compose — иначе в контейнер переменные не попадут (см. дефолты только в коде clicker).
# 1 — проверка фрагментов codegen через Playwright MCP; 0 — запасной режим run_fragment.mjs.
CODEGEN_USE_PLAYWRIGHT_MCP=1
# Playwright MCP: раннеры в коде передают --isolated (эфемерный контекст). Без этого MCP держит
# persistent profile на диске — состояние сайта (корзина, сессия) переживает следующий прогон.
# 0 — валидация сгенерированного JS в браузере; 1 — только LLM (не для прода).
CODEGEN_SKIP_BROWSER_VALIDATE=0
# 1 — в промпт codegen подмешивать фрагмент trace.trace из trace.zip успешного VLM-прогона (тот же run_id); 0 — отключить.
CODEGEN_VLM_TRACE_EXCERPT=1
# VLM-прогон: сохранять page.content + focused DOM в MinIO на каждый шаг (vlm_dom/{step_uid}.before.*).
VLM_SAVE_STEP_HTML=1
# Codegen: использовать focused DOM из успешного VLM run в draft/repair (при наличии артефактов).
CODEGEN_USE_VLM_STEP_HTML=1
# По умолчанию off — шум; включите при отладке агента.
# CODEGEN_VLM_RUN_LOG=1
# По умолчанию off — head/tail trace; включите при отладке.
# CODEGEN_VLM_TRACE_GLOBAL_SUMMARY=1
