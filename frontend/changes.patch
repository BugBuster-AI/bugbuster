+import BBLogo from '@Assets/icons/black_bb_logo.svg?react'
+import ScreenmateLogo from '@Assets/icons/screenmate_logo.svg?react'
+import { VERSION } from '@Common/consts/env';
+import { Flex, Typography } from 'antd';
+import { useTranslation } from 'react-i18next';
+
+const getLogo = () => {
+
+    if (VERSION === 'ru') {
+        return <BBLogo height={ 24 }/>
+    }
+
+    return <ScreenmateLogo height={ 24 }/>
+}
+
+export const MobilePlaceholder = () => {
+    const version = VERSION
+    const { t } = useTranslation()
+
+    return (
+        <Flex
+            align={ 'center' }
+            flex={ 1 }
+            justify={ 'center' }
+            style={ { width: '100vw', height: '100dvh', padding: '16px' } }
+        >
+            <Flex align={ 'center' } gap={ 16 } vertical>
+                {getLogo()}
+                <Typography.Text style={ { textAlign: 'center' } }>{t(`mobilePlaceholder.${version}`)}</Typography.Text>
+            </Flex>
+        </Flex>
+    )
+}
